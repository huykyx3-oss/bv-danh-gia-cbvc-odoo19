<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="bv_danh_gia.Dashboard">
    <div class="bv-dashboard">
        <t t-if="state.loading">
            <div style="text-align:center;padding:60px;">
                <i class="fa fa-spinner fa-spin fa-3x" style="color:#c9a84c;"/>
                <p style="margin-top:16px;color:#6b6760;">Đang tải dữ liệu...</p>
            </div>
        </t>
        <t t-else="">
            <!-- Header -->
            <div class="bv-dashboard-header">
                <h1>Dashboard Đánh giá CBVC</h1>
                <p>
                    <t t-esc="roleLabel"/>
                    <t t-if="state.data.employee_name"> · <t t-esc="state.data.employee_name"/></t>
                </p>
            </div>

            <!-- Pending approvals for managers/HR -->
            <t t-if="state.data.role === 'hospital'">
                <div class="bv-stats-grid" style="margin-bottom:16px;">
                    <div class="bv-stat-card" style="border-left:4px solid #ffc107;cursor:pointer;" t-on-click="openPendingDept">
                        <div class="bv-stat-card-label">Chờ trưởng khoa duyệt</div>
                        <div class="bv-stat-card-value" style="color:#856404;"><t t-esc="state.data.pending_dept"/></div>
                        <div class="bv-stat-card-sub">phiếu</div>
                    </div>
                    <div class="bv-stat-card" style="border-left:4px solid #17a2b8;cursor:pointer;" t-on-click="openPendingHR">
                        <div class="bv-stat-card-label">Chờ TCCB xét duyệt</div>
                        <div class="bv-stat-card-value" style="color:#0c5460;"><t t-esc="state.data.pending_hr"/></div>
                        <div class="bv-stat-card-sub">phiếu</div>
                    </div>
                    <div class="bv-stat-card" style="border-left:4px solid #0f2044;">
                        <div class="bv-stat-card-label">Chờ BGĐ phê duyệt</div>
                        <div class="bv-stat-card-value" style="color:#0f2044;"><t t-esc="state.data.pending_director"/></div>
                        <div class="bv-stat-card-sub">phiếu</div>
                    </div>
                </div>
            </t>

            <t t-if="state.data.role === 'department' and state.data.pending_approval > 0">
                <div class="bv-ratio-alert" style="cursor:pointer;" t-on-click="openPendingDept">
                    <strong>Có <t t-esc="state.data.pending_approval"/> phiếu</strong> đang chờ duyệt trong khoa/phòng của bạn.
                </div>
            </t>

            <!-- Stats cards -->
            <div class="bv-stats-grid">
                <div class="bv-stat-card bv-total">
                    <div class="bv-stat-card-label">Tổng phiếu đã duyệt</div>
                    <div class="bv-stat-card-value"><t t-esc="state.data.total_evaluations"/></div>
                    <div class="bv-stat-card-sub">Điểm trung bình: <strong><t t-esc="state.data.avg_score"/></strong></div>
                </div>
                <div class="bv-stat-card bv-excellent">
                    <div class="bv-stat-card-label">Xuất sắc</div>
                    <div class="bv-stat-card-value"><t t-esc="state.data.excellent_count"/></div>
                    <div class="bv-stat-card-sub">
                        Tỷ lệ: <strong><t t-esc="state.data.ratio_excellent_actual"/>%</strong>
                        (giới hạn <t t-esc="state.data.ratio_excellent"/>%)
                    </div>
                </div>
                <div class="bv-stat-card bv-good">
                    <div class="bv-stat-card-label">Tốt</div>
                    <div class="bv-stat-card-value"><t t-esc="state.data.good_count"/></div>
                </div>
                <div class="bv-stat-card bv-fair">
                    <div class="bv-stat-card-label">Hoàn thành</div>
                    <div class="bv-stat-card-value"><t t-esc="state.data.fair_count"/></div>
                </div>
                <div class="bv-stat-card bv-poor">
                    <div class="bv-stat-card-label">Không hoàn thành</div>
                    <div class="bv-stat-card-value"><t t-esc="state.data.poor_count"/></div>
                </div>
            </div>

            <!-- Ratio warning -->
            <t t-if="ratioExceeded">
                <div class="bv-ratio-alert">
                    <strong>Cảnh báo:</strong> Tỷ lệ xếp loại "Xuất sắc" hiện tại là
                    <strong><t t-esc="state.data.ratio_excellent_actual"/>%</strong>,
                    vượt quá giới hạn cho phép
                    <strong><t t-esc="state.data.ratio_excellent"/>%</strong>.
                </div>
            </t>
            <t t-else="">
                <t t-if="state.data.total_evaluations > 0">
                    <div class="bv-ratio-ok">
                        Tỷ lệ "Xuất sắc": <strong><t t-esc="state.data.ratio_excellent_actual"/>%</strong>
                        / giới hạn <strong><t t-esc="state.data.ratio_excellent"/>%</strong> — Hợp lệ.
                    </div>
                </t>
            </t>

            <!-- Điểm NV / TK-TP theo tháng (connected scatter) -->
            <div class="bv-chart-section">
                <div class="bv-chart-section-title">Biểu đồ điểm theo tháng</div>
                <div class="bv-chart-section-sub">
                    Điểm NV tự chấm và TK/TP chấm (phiếu đã duyệt), nối theo thời gian —
                    năm <strong t-esc="state.chartMeta and state.chartMeta.year or state.chartYear"/>.
                </div>
                <div class="bv-chart-filters" t-if="state.data">
                    <label>
                        Năm
                        <select class="form-select" t-on-change="onChartYearChange">
                            <t t-foreach="yearOptions" t-as="yy" t-key="yy">
                                <option t-att-value="yy" t-esc="yy" t-att-selected="yy === state.chartYear"/>
                            </t>
                        </select>
                    </label>
                    <t t-if="state.data.role === 'hospital'">
                        <label>
                            Chế độ
                            <select class="form-select" t-on-change="onChartModeChange">
                                <option value="avg_all" t-att-selected="state.chartMode === 'avg_all'">TB toàn viện</option>
                                <option value="department" t-att-selected="state.chartMode === 'department'">Theo khoa/phòng</option>
                                <option value="employee" t-att-selected="state.chartMode === 'employee'">Theo nhân viên</option>
                            </select>
                        </label>
                        <label t-if="state.chartMode === 'department'">
                            Khoa / phòng
                            <select class="form-select" t-on-change="onChartDeptForAvgChange">
                                <option value="">— Chọn —</option>
                                <t t-foreach="state.chartDepartments" t-as="dep" t-key="dep.id">
                                    <option t-att-value="dep.id" t-esc="dep.name"
                                        t-att-selected="dep.id === state.chartDeptForAvg"/>
                                </t>
                            </select>
                        </label>
                        <label t-if="state.chartMode === 'employee'">
                            Lọc khoa (tuỳ chọn)
                            <select class="form-select" t-on-change="onChartEmployeeDeptFilterChange">
                                <option value="">Tất cả</option>
                                <t t-foreach="state.chartDepartments" t-as="dep" t-key="dep.id">
                                    <option t-att-value="dep.id" t-esc="dep.name"
                                        t-att-selected="dep.id === state.chartDeptFilterForEmployee"/>
                                </t>
                            </select>
                        </label>
                        <label t-if="state.chartMode === 'employee'">
                            Nhân viên
                            <select class="form-select" t-on-change="onChartEmployeeChange">
                                <option value="">— Chọn nhân viên —</option>
                                <t t-foreach="state.chartEmployees" t-as="emp" t-key="emp.id">
                                    <option t-att-value="emp.id" t-esc="emp.name"
                                        t-att-selected="emp.id === state.chartEmployeeId"/>
                                </t>
                            </select>
                        </label>
                    </t>
                    <t t-if="state.data.role === 'department'">
                        <label>
                            Chế độ
                            <select class="form-select" t-on-change="onChartModeChange">
                                <option value="avg_all" t-att-selected="state.chartMode === 'avg_all'">TB khoa/phòng</option>
                                <option value="employee" t-att-selected="state.chartMode === 'employee'">Theo nhân viên</option>
                            </select>
                        </label>
                        <label t-if="state.chartMode === 'employee'">
                            Nhân viên trong khoa
                            <select class="form-select" t-on-change="onChartEmployeeChange">
                                <option value="">— Chọn nhân viên —</option>
                                <t t-foreach="state.chartEmployees" t-as="emp" t-key="emp.id">
                                    <option t-att-value="emp.id" t-esc="emp.name"
                                        t-att-selected="emp.id === state.chartEmployeeId"/>
                                </t>
                            </select>
                        </label>
                    </t>
                    <t t-if="state.data.role === 'employee'">
                        <span style="font-size:13px;color:#6b6760;">Chỉ hiển thị dữ liệu của bạn.</span>
                    </t>
                </div>
                <t t-if="state.chartLoading">
                    <div style="text-align:center;padding:32px;color:#6b6760;">
                        <i class="fa fa-spinner fa-spin"/> Đang tải biểu đồ…
                    </div>
                </t>
                <t t-else="">
                    <div class="bv-chart-svg-wrap">
                        <svg viewBox="0 0 560 260" class="bv-chart-svg" preserveAspectRatio="xMidYMid meet">
                            <rect class="bv-chart-axis" fill="none"
                                t-att-x="chartGeometry.padL - 1" t-att-y="chartGeometry.padT - 1"
                                t-att-width="chartGeometry.innerW + 2" t-att-height="chartGeometry.innerH + 2"/>
                            <t t-foreach="chartYTicks" t-as="tk" t-key="tk_index + '-grid'">
                                <line class="bv-chart-grid"
                                    t-att-x1="chartGeometry.padL" t-att-y1="tk.y"
                                    t-att-x2="chartGeometry.padL + chartGeometry.innerW" t-att-y2="tk.y"/>
                            </t>
                            <t t-foreach="chartYTicks" t-as="tk" t-key="tk_index + '-ylab'">
                                <text fill="#8a8478" font-size="10" text-anchor="end"
                                    t-att-x="chartGeometry.padL - 6" t-att-y="tk.y + 4" t-esc="tk.label"/>
                            </t>
                            <t t-if="chartNvPolylinePoints">
                                <polyline class="bv-chart-line-nv" t-att-points="chartNvPolylinePoints"/>
                            </t>
                            <t t-if="chartTpPolylinePoints">
                                <polyline class="bv-chart-line-tp" t-att-points="chartTpPolylinePoints"/>
                            </t>
                            <t t-foreach="chartNvDots" t-as="pt" t-key="'nv-' + pt.month">
                                <circle class="bv-chart-dot-nv" r="4"
                                    t-att-cx="pt.x" t-att-cy="pt.y"/>
                            </t>
                            <t t-foreach="chartTpDots" t-as="pt" t-key="'tp-' + pt.month">
                                <circle class="bv-chart-dot-tp" r="4"
                                    t-att-cx="pt.x" t-att-cy="pt.y"/>
                            </t>
                            <t t-foreach="chartMonthLabelPositions" t-as="ml" t-key="ml.m">
                                <text fill="#6b6760" font-size="9.5" text-anchor="middle"
                                    t-att-x="ml.x" t-att-y="chartGeometry.H - 10" t-esc="ml.label"/>
                            </t>
                        </svg>
                    </div>
                    <div class="bv-chart-legend">
                        <span><i class="nv"/> NV tự chấm</span>
                        <span><i class="tp"/> TK / TP chấm</span>
                    </div>
                    <div t-if="!chartHasAnyPoint" class="bv-chart-empty-hint" style="margin-top:10px;font-size:12px;color:#8a8478;">
                        Không có điểm để hiển thị: chưa có phiếu <strong>đã duyệt</strong> trong năm đã chọn, hoặc chưa chọn nhân viên/khoa (chế độ lọc).
                    </div>
                </t>
            </div>

            <!-- Department breakdown table (hospital-wide view) -->
            <t t-if="state.data.role === 'hospital' and state.data.department_breakdown and state.data.department_breakdown.length > 0">
                <div class="bv-dept-table">
                    <div class="bv-dept-table-header">Thống kê theo Khoa / Phòng</div>
                    <table>
                        <thead>
                            <tr>
                                <th>Khoa / Phòng</th>
                                <th style="text-align:center">Tổng</th>
                                <th style="text-align:center">Xuất sắc</th>
                                <th style="text-align:center">Tốt</th>
                                <th style="text-align:center">Hoàn thành</th>
                                <th style="text-align:center">Không HT</th>
                                <th style="text-align:center">ĐTB</th>
                                <th style="text-align:center">% XS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.department_breakdown" t-as="dept" t-key="dept.name">
                                <tr>
                                    <td><strong><t t-esc="dept.name"/></strong></td>
                                    <td style="text-align:center"><t t-esc="dept.total"/></td>
                                    <td style="text-align:center;color:#856404;font-weight:600;"><t t-esc="dept.excellent"/></td>
                                    <td style="text-align:center;color:#0c5460;"><t t-esc="dept.good"/></td>
                                    <td style="text-align:center;color:#155724;"><t t-esc="dept.fair"/></td>
                                    <td style="text-align:center;color:#b03030;"><t t-esc="dept.poor"/></td>
                                    <td style="text-align:center;font-weight:700;"><t t-esc="dept.avg_score"/></td>
                                    <td style="text-align:center;">
                                        <span t-att-style="dept.ratio_excellent > state.data.ratio_excellent ? 'color:#b03030;font-weight:700;' : 'color:#155724;'">
                                            <t t-esc="dept.ratio_excellent"/>%
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>

            <!-- Recent evaluations (employee view) -->
            <t t-if="state.data.role === 'employee' and state.data.recent_evaluations and state.data.recent_evaluations.length > 0">
                <div class="bv-dept-table">
                    <div class="bv-dept-table-header">Phiếu đánh giá gần đây</div>
                    <table>
                        <thead>
                            <tr>
                                <th>Kỳ đánh giá</th>
                                <th style="text-align:center">Tổng điểm</th>
                                <th style="text-align:center">Xếp loại</th>
                                <th style="text-align:center">Trạng thái</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.data.recent_evaluations" t-as="ev" t-key="ev.id">
                                <tr style="cursor:pointer;" t-on-click="() => this.openEvaluation(ev.id)">
                                    <td><strong><t t-esc="ev.month"/>/<t t-esc="ev.year"/></strong></td>
                                    <td style="text-align:center;font-weight:700;"><t t-esc="ev.total_score"/></td>
                                    <td style="text-align:center;"><t t-esc="classificationLabel[ev.classification] || ''"/></td>
                                    <td style="text-align:center;"><t t-esc="stateLabel[ev.state] || ev.state"/></td>
                                    <td style="text-align:center;"><i class="fa fa-chevron-right" style="color:#c5c1b8;"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>

            <!-- Quick actions -->
            <div class="bv-action-bar" style="margin-top:16px;">
                <button class="btn btn-primary" t-on-click="openMyEvaluations" style="background:#0f2044;border:none;padding:11px 24px;border-radius:8px;font-weight:600;">
                    Xem tất cả phiếu đánh giá
                </button>
            </div>
        </t>
    </div>
</t>

</templates>
