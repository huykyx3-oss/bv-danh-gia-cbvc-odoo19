<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_evaluation_template_form" model="ir.ui.view">
        <field name="name">bv.evaluation.template.form</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_duplicate_template" string="Tạo bản sao"
                            type="object" class="btn-secondary"
                            groups="bv_danh_gia.group_evaluation_hr"/>
                    <button name="action_apply_to_evaluations" string="Đồng bộ tiêu chí vào hệ thống"
                            type="object" class="btn-primary"
                            groups="bv_danh_gia.group_evaluation_hr"
                            confirm="Bạn có chắc muốn đồng bộ các tiêu chí từ biểu mẫu này vào hệ thống tiêu chí đánh giá?"/>
                    <button name="action_archive" string="Lưu trữ (Ngừng sử dụng)"
                            type="object" class="btn-danger"
                            invisible="not active"
                            groups="bv_danh_gia.group_evaluation_hr"
                            confirm="Biểu mẫu sẽ bị lưu trữ và không còn hiển thị khi tạo phiếu đánh giá mới. Tiếp tục?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button"
                                icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên biểu mẫu đánh giá..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="template_type"/>
                            <field name="apply_to"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="year_from"/>
                            <field name="year_to"/>
                            <field name="workflow_steps"/>
                            <field name="task_score_weight"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Mô tả biểu mẫu, căn cứ pháp lý..."/>
                    </group>

                    <notebook>
                        <page string="Tiêu chí đánh giá">
                            <field name="criteria_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="parent_line_id"
                                           domain="[('template_id', '=', parent.id)]"/>
                                    <field name="max_score"/>
                                    <field name="note" optional="hide"/>
                                    <field name="synced_criteria_id" readonly="1" optional="hide"/>
                                </list>
                            </field>
                            <group>
                                <field name="total_general_score" readonly="1"
                                       string="Tổng điểm tiêu chí chung" decoration-bf="1"/>
                            </group>
                        </page>
                    </notebook>

                    <group string="Thông tin tạo">
                        <field name="created_by" readonly="1"/>
                        <field name="date_created" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_evaluation_template_tree" model="ir.ui.view">
        <field name="name">bv.evaluation.template.tree</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="template_type"/>
                <field name="apply_to"/>
                <field name="workflow_steps"/>
                <field name="total_general_score"/>
                <field name="task_score_weight"/>
                <field name="year_from"/>
                <field name="year_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_evaluation_template_search" model="ir.ui.view">
        <field name="name">bv.evaluation.template.search</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_evaluation_template" model="ir.actions.act_window">
        <field name="name">Biểu mẫu đánh giá</field>
        <field name="res_model">bv.evaluation.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo biểu mẫu đánh giá mới
            </p>
            <p>
                Phòng TCCB tạo biểu mẫu với danh sách tiêu chí, điểm tối đa và quy trình duyệt.
                Sau khi lưu, hệ thống <strong>tự đồng bộ tiêu chí</strong> — nhân viên có thể chọn biểu mẫu này ngay.
            </p>
        </field>
    </record>
</odoo>
