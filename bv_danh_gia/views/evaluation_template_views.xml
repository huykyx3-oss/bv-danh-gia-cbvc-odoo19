<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_evaluation_template_form" model="ir.ui.view">
        <field name="name">bv.evaluation.template.form</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_duplicate_template" string="Tạo bản sao"
                            type="object" class="btn-secondary"
                            groups="bv_danh_gia.group_evaluation_hr"/>
                    <button name="action_apply_to_evaluations" string="Đồng bộ tiêu chí vào hệ thống"
                            type="object" class="btn-primary"
                            groups="bv_danh_gia.group_evaluation_hr"
                            confirm="Bạn có chắc muốn đồng bộ các tiêu chí từ biểu mẫu này vào hệ thống tiêu chí đánh giá?"/>
                    <button name="action_archive" string="Lưu trữ (Ngừng sử dụng)"
                            type="object" class="btn-danger"
                            invisible="not active"
                            groups="bv_danh_gia.group_evaluation_hr"
                            confirm="Biểu mẫu sẽ bị lưu trữ và không còn hiển thị khi tạo phiếu đánh giá mới. Tiếp tục?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button"
                                icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên biểu mẫu đánh giá..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="template_type"/>
                            <field name="apply_to"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="year_from"/>
                            <field name="year_to"/>
                            <field name="workflow_steps"
                                   help="Áp dụng cho mọi phiếu đánh giá hằng tháng chọn biểu mẫu này. Hai chế độ thường dùng: (1) NV→TK/TP→TCCB→BGĐ; (2) NV→TK/TP→TCCB xong; (3) NV→TK/TP xong."/>
                            <field name="task_score_weight"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Mô tả biểu mẫu, căn cứ pháp lý..."/>
                    </group>

                    <notebook>
                        <page string="Nhãn tiêu chí KQTHNV"
                              groups="bv_danh_gia.group_evaluation_hr">
                            <div class="alert alert-info" role="alert">
                                <strong>Lưu ý:</strong> Chỉ chỉnh tên hiển thị.
                                Không thêm/bớt tiêu chí để giữ nguyên công thức tính điểm.
                            </div>
                            <group string="Tiêu chí cơ bản (tất cả CBVC)">
                                <field name="label_pct_a"/>
                                <field name="label_pct_b"/>
                                <field name="label_pct_c"/>
                            </group>
                            <group string="Tiêu chí bổ sung (lãnh đạo, quản lý)">
                                <field name="label_pct_d"/>
                                <field name="label_pct_dd"/>
                                <field name="label_pct_e"/>
                            </group>
                        </page>

                        <page string="Tiêu chí đánh giá">
                            <div class="alert alert-info" style="margin-bottom:10px;">
                                <strong>Hướng dẫn nhập tiêu chí:</strong>
                                <ol style="margin:4px 0 0 0;padding-left:18px;">
                                    <li>Bấm <strong>"Thêm dòng"</strong> bên dưới để thêm 1 tiêu chí mới.</li>
                                    <li>Ở cột <strong>"Tiêu chí (chọn từ danh mục)"</strong>, gõ <em>tên</em> hoặc <em>mã</em> tiêu chí — hệ thống sẽ gợi ý các tiêu chí có sẵn trong danh mục.</li>
                                    <li>Khi chọn xong, các cột <strong>Mã</strong>, <strong>Tên</strong>, <strong>Tiêu chí cha</strong> tự động điền (đồng bộ với màn "Cấu hình tiêu chí đánh giá").</li>
                                    <li>Nếu tiêu chí chưa có trong danh mục, bấm <strong>"Tạo và chỉnh sửa..."</strong> trong dropdown để thêm vào danh mục ngay.</li>
                                    <li>Có thể chỉnh <strong>Điểm tối đa</strong> riêng cho biểu mẫu này (ban đầu lấy từ danh mục).</li>
                                </ol>
                                <hr style="margin:8px 0;"/>
                                <strong>Giải thích các trường:</strong>
                                <ul style="margin:4px 0 0 0;padding-left:18px;">
                                    <li><strong>Thứ tự:</strong> Số nhỏ hơn hiển thị lên đầu (10, 20, 30…). Có thể kéo thả ô bên trái để đổi thứ tự.</li>
                                    <li><strong>Trọng số điểm KQTHNV</strong> (tab thông tin chung): Điểm tối đa của Phần II — mặc định <strong>70</strong>/100. Phần I (tiêu chí chung) chiếm 30 điểm còn lại.</li>
                                </ul>
                            </div>
                            <field name="criteria_ids">
                                <list editable="bottom" no_open="1">
                                    <field name="sequence" widget="handle" string="Seq"/>
                                    <field name="criteria_id"
                                           string="Tiêu chí (chọn từ danh mục)"
                                           options='{"no_quick_create": true, "no_open": true}'
                                           context="{'default_category': 'general', 'default_active': True}"
                                           required="1"/>
                                    <field name="code" readonly="1" force_save="1" optional="show"/>
                                    <field name="parent_id"
                                           string="Tiêu chí cha"
                                           readonly="1" force_save="1"
                                           optional="show"/>
                                    <field name="max_score" string="Điểm tối đa"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                            <group>
                                <field name="total_general_score" readonly="1"
                                       string="Tổng điểm tiêu chí chung" decoration-bf="1"/>
                            </group>
                        </page>
                    </notebook>

                    <group string="Thông tin tạo">
                        <field name="created_by" readonly="1"/>
                        <field name="date_created" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_evaluation_template_tree" model="ir.ui.view">
        <field name="name">bv.evaluation.template.tree</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="template_type"/>
                <field name="apply_to"/>
                <field name="workflow_steps"/>
                <field name="total_general_score"/>
                <field name="task_score_weight"/>
                <field name="year_from"/>
                <field name="year_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_evaluation_template_search" model="ir.ui.view">
        <field name="name">bv.evaluation.template.search</field>
        <field name="model">bv.evaluation.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_evaluation_template" model="ir.actions.act_window">
        <field name="name">Biểu mẫu đánh giá</field>
        <field name="res_model">bv.evaluation.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo biểu mẫu đánh giá mới
            </p>
            <p>
                Phòng TCCB tạo biểu mẫu với danh sách tiêu chí, điểm tối đa và quy trình duyệt.
                Sau khi lưu, hệ thống <strong>tự đồng bộ tiêu chí</strong> — nhân viên có thể chọn biểu mẫu này ngay.
            </p>
        </field>
    </record>
</odoo>
