<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View — import enabled -->
    <record id="view_evaluation_criteria_tree" model="ir.ui.view">
        <field name="name">bv.evaluation.criteria.tree</field>
        <field name="model">bv.evaluation.criteria</field>
        <field name="arch" type="xml">
            <list import="1" export_xlsx="1">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="category"/>
                <field name="max_score"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_evaluation_criteria_search" model="ir.ui.view">
        <field name="name">bv.evaluation.criteria.search</field>
        <field name="model">bv.evaluation.criteria</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Tên tiêu chí"/>
                <field name="code"/>
                <filter name="general" string="Tiêu chí chung"
                        domain="[('category','=','general')]"/>
                <filter name="task" string="Kết quả nhiệm vụ"
                        domain="[('category','=','task_result')]"/>
                <filter name="leaf" string="Tiêu chí lá (có thể chấm điểm)"
                        domain="[('is_parent','=',False)]"/>
                <filter name="active" string="Đang sử dụng"
                        domain="[('active','=',True)]"/>
                <separator/>
                <filter name="group_by_category" string="Nhóm theo: Phân loại"
                        context="{'group_by': 'category'}"/>
                <filter name="group_by_parent" string="Nhóm theo: Tiêu chí cha"
                        context="{'group_by': 'parent_id'}"/>
            </search>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_evaluation_criteria_form" model="ir.ui.view">
        <field name="name">bv.evaluation.criteria.form</field>
        <field name="model">bv.evaluation.criteria</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="max_score"/>
                        </group>
                        <group>
                            <field name="parent_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ghi chú / Hướng dẫn chấm">
                            <field name="note" placeholder="Nhập hướng dẫn chấm điểm cho tiêu chí này..."/>
                        </page>
                        <page string="Tiêu chí con" invisible="not is_parent">
                            <field name="child_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="max_score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_evaluation_criteria" model="ir.actions.act_window">
        <field name="name">Cấu hình tiêu chí đánh giá</field>
        <field name="res_model">bv.evaluation.criteria</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo tiêu chí đánh giá mới
            </p>
        </field>
    </record>
</odoo>
