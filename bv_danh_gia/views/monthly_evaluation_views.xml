<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== FORM VIEW ========== -->
    <record id="view_monthly_evaluation_form" model="ir.ui.view">
        <field name="name">bv.monthly.evaluation.form</field>
        <field name="model">bv.monthly.evaluation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Gửi đánh giá"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="bv_danh_gia.group_evaluation_user"/>
                    <button name="action_dept_approve" string="Trưởng khoa duyệt"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="bv_danh_gia.group_evaluation_dept_manager"/>
                    <button name="action_hr_review" string="TCCB xét duyệt"
                            type="object" class="btn-primary"
                            invisible="state != 'dept_approved'"
                            groups="bv_danh_gia.group_evaluation_hr"/>
                    <button name="action_approve" string="BGĐ phê duyệt"
                            type="object" class="btn-primary"
                            invisible="state != 'hr_reviewed'"
                            groups="bv_danh_gia.group_evaluation_director"/>
                    <button name="action_reject" string="Trả lại"
                            type="object" class="btn-danger"
                            invisible="state in ('draft', 'approved', 'rejected')"
                            groups="bv_danh_gia.group_evaluation_dept_manager"/>
                    <button name="action_reset_draft" string="Đặt lại nháp"
                            type="object"
                            invisible="state not in ('rejected', 'submitted')"
                            groups="bv_danh_gia.group_evaluation_user"/>
                    <button string="Xuất Word (DOCX)" type="object"
                            name="action_export_docx" class="btn-secondary"
                            icon="fa-file-word-o"/>
                    <button string="Giao diện đánh giá mới" type="object"
                            name="action_open_custom_form" class="btn-primary"
                            icon="fa-paint-brush"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,dept_approved,hr_reviewed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- BƯỚC 1: Chọn biểu mẫu -->
                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        <strong>Hướng dẫn:</strong>
                        Chọn <strong>Biểu mẫu đánh giá</strong> do Phòng TCCB ban hành → các tiêu chí sẽ tự động hiện ra.
                        Sau đó điền tháng/năm và chấm điểm từng tiêu chí.
                    </div>

                    <group string="1. Chọn biểu mẫu đánh giá">
                        <field name="template_id"
                               readonly="state != 'draft'"
                               options="{'no_create': True, 'no_edit': True}"
                               domain="[('active', '=', True), ('template_type', '=', 'monthly')]"
                               placeholder="-- Chọn biểu mẫu do TCCB ban hành --"/>
                    </group>

                    <group string="2. Thông tin kỳ đánh giá">
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="is_manager"/>
                        </group>
                        <group>
                            <field name="month" readonly="state != 'draft'"/>
                            <field name="year" readonly="state != 'draft'"/>
                            <field name="quarter" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1: Tiêu chí chung -->
                        <page string="I. Tiêu chí chung">
                            <group>
                                <field name="general_score_max" readonly="1"
                                       string="Điểm tối đa phần I (theo biểu mẫu)"/>
                            </group>
                            <field name="criteria_line_ids"
                                   readonly="state != 'draft' and not can_edit_dept_score">
                                <list editable="bottom" create="false">
                                    <field name="parent_criteria_id" optional="show" readonly="1"/>
                                    <field name="criteria_id" readonly="1" force_save="1"/>
                                    <field name="max_score" readonly="1"/>
                                    <field name="self_score"
                                           readonly="parent.state != 'draft'"
                                           string="NV tự chấm"/>
                                    <field name="dept_score"
                                           readonly="not parent.can_edit_dept_score"
                                           string="TK/TP chấm"
                                           column_invisible="parent.state == 'draft'"
                                           optional="show"/>
                                    <field name="final_score" readonly="1"
                                           decoration-bf="1"
                                           string="Điểm cuối"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                            <group>
                                <field name="general_score" readonly="1"
                                       class="oe_inline"/>
                            </group>
                        </page>

                        <!-- Tab 2: Điểm KQTHNV -->
                        <page string="II. Điểm KQTHNV">
                            <group>
                                <field name="task_score_max" readonly="1"
                                       string="Điểm tối đa KQTHNV (theo biểu mẫu)"/>
                            </group>

                            <!-- Tiêu chí cơ bản — bảng 4 cột -->
                            <div class="bv-kqtnv-section">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Tiêu chí cơ bản (tất cả CBVC)</div>
                                    <div class="bv-kq-c-nv">NV tự chấm (%)</div>
                                    <div class="bv-kq-c-tp">TK/TP chấm (%)</div>
                                    <div class="bv-kq-c-ev">Minh chứng PDF</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">a – <field name="label_pct_a" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_quantity" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_quantity" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_quantity" widget="binary" filename="evidence_quantity_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_quantity_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">b – <field name="label_pct_b" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_quality" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_quality" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_quality" widget="binary" filename="evidence_quality_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_quality_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">c – <field name="label_pct_c" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_progress" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_progress" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_progress" widget="binary" filename="evidence_progress_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_progress_name" invisible="1"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Tiêu chí lãnh đạo — bảng 4 cột -->
                            <div class="bv-kqtnv-section bv-kqtnv-section--mgr" invisible="not is_manager">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Tiêu chí bổ sung (lãnh đạo, quản lý)</div>
                                    <div class="bv-kq-c-nv">NV tự chấm (%)</div>
                                    <div class="bv-kq-c-tp">TK/TP chấm (%)</div>
                                    <div class="bv-kq-c-ev">Minh chứng PDF</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">d – <field name="label_pct_d" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_field_result" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_field_result" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_field_result" widget="binary" filename="evidence_field_result_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_field_result_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">đ – <field name="label_pct_dd" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_organization" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_organization" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_organization" widget="binary" filename="evidence_organization_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_organization_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">e – <field name="label_pct_e" nolabel="1" readonly="1" class="oe_inline"/></div>
                                    <div class="bv-kq-c-nv"><field name="pct_team_cohesion" nolabel="1" readonly="state not in ('draft', 'submitted')"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_team_cohesion" nolabel="1" readonly="not can_edit_dept_score" invisible="not can_edit_dept_score and state not in ('dept_approved', 'hr_reviewed', 'approved')"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_team_cohesion" widget="binary" filename="evidence_team_cohesion_name" nolabel="1" readonly="state != 'draft'"/>
                                        <field name="evidence_team_cohesion_name" invisible="1"/>
                                    </div>
                                </div>
                            </div>

                            <group>
                                <field name="task_score" readonly="1" class="oe_inline"/>
                            </group>
                        </page>

                        <!-- Tab 3: Tổng hợp -->
                        <page string="III. Tổng hợp kết quả">
                            <div class="bv-kqtnv-section">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Khoản mục</div>
                                    <div class="bv-kq-c-nv">NV tự chấm</div>
                                    <div class="bv-kq-c-tp" style="flex:1;">TK/TP chấm (hiện tại)</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">I. Tiêu chí chung</div>
                                    <div class="bv-kq-c-nv"><field name="general_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="general_score" readonly="1" nolabel="1"/></div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">II. Điểm KQTHNV</div>
                                    <div class="bv-kq-c-nv"><field name="task_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="task_score" readonly="1" nolabel="1"/></div>
                                </div>
                                <div class="bv-kqtnv-row" style="font-weight:700;">
                                    <div class="bv-kq-c-label">Tổng điểm</div>
                                    <div class="bv-kq-c-nv"><field name="total_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="total_score" readonly="1" nolabel="1" decoration-bf="1"/></div>
                                </div>
                            </div>
                            <group>
                                <field name="classification" readonly="1" decoration-bf="1"/>
                            </group>
                            <separator string="Nhận xét"/>
                            <group>
                                <field name="strengths"
                                       placeholder="Ưu điểm..."
                                       readonly="state == 'approved'"/>
                                <field name="weaknesses"
                                       placeholder="Hạn chế, khuyết điểm..."
                                       readonly="state == 'approved'"/>
                                <field name="authority_comment"
                                       placeholder="Ý kiến nhận xét của cấp có thẩm quyền..."
                                       groups="bv_danh_gia.group_evaluation_dept_manager"
                                       readonly="state == 'approved'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ========== DEPT MANAGER APPROVAL FORM VIEW ========== -->
    <record id="view_monthly_evaluation_dept_form" model="ir.ui.view">
        <field name="name">bv.monthly.evaluation.dept.form</field>
        <field name="model">bv.monthly.evaluation</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_dept_approve" string="✔ Xác nhận điểm &amp; Duyệt"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="bv_danh_gia.group_evaluation_dept_manager"
                            confirm="Bạn xác nhận đã chấm điểm và đồng ý duyệt phiếu này?"/>
                    <button name="action_reject" string="Trả lại nhân viên"
                            type="object" class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="bv_danh_gia.group_evaluation_dept_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,dept_approved,hr_reviewed,approved"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert"
                         invisible="state != 'submitted'">
                        <strong>Hướng dẫn:</strong> Nhập điểm của bạn vào cột
                        <strong>"Điểm TK/TP chấm"</strong>. Cột "Điểm NV tự chấm" chỉ để tham khảo,
                        không chỉnh sửa được. Sau khi chấm xong, nhấn
                        <strong>"Xác nhận điểm &amp; Duyệt"</strong>.
                    </div>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin nhân viên">
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="is_manager" readonly="1"/>
                        </group>
                        <group string="Kỳ đánh giá">
                            <field name="month" readonly="1"/>
                            <field name="year" readonly="1"/>
                            <field name="total_score" readonly="1" decoration-bf="1"/>
                            <field name="classification" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="I. Tiêu chí chung — Chấm điểm">
                            <field name="criteria_line_ids"
                                   readonly="state != 'submitted'">
                                <list editable="bottom" create="false">
                                    <field name="parent_criteria_id" readonly="1" optional="show"/>
                                    <field name="criteria_id" readonly="1" force_save="1"/>
                                    <field name="max_score" readonly="1"/>
                                    <field name="self_score" readonly="1"
                                           string="NV tự chấm"
                                           decoration-muted="1"/>
                                    <field name="dept_score"
                                           string="TK/TP chấm ✏"
                                           decoration-bf="parent.state == 'submitted'"
                                           decoration-success="dept_score >= self_score"
                                           decoration-warning="dept_score &lt; self_score"/>
                                    <field name="final_score" readonly="1"
                                           string="Điểm cuối"
                                           decoration-bf="1"/>
                                    <field name="note" optional="show" string="Ghi chú TK"/>
                                </list>
                            </field>
                            <group>
                                <field name="general_score" readonly="1" decoration-bf="1"/>
                            </group>
                        </page>

                        <page string="II. Điểm KQTHNV">
                            <div class="alert alert-warning" role="alert"
                                 invisible="state != 'submitted'">
                                Nhập điểm % của <strong>Trưởng khoa/phòng</strong> vào cột TK/TP chấm.
                                Cột NV tự chấm chỉ để tham khảo.
                            </div>

                            <!-- Tiêu chí cơ bản — bảng 4 cột -->
                            <div class="bv-kqtnv-section">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Tiêu chí cơ bản (tất cả CBVC)</div>
                                    <div class="bv-kq-c-nv">NV tự chấm (%)</div>
                                    <div class="bv-kq-c-tp">TK/TP chấm (%)</div>
                                    <div class="bv-kq-c-ev">Minh chứng PDF (NV nộp)</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">a – % Số lượng</div>
                                    <div class="bv-kq-c-nv"><field name="pct_quantity" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_quantity" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_quantity" widget="binary" filename="evidence_quantity_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_quantity_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">b – % Chất lượng</div>
                                    <div class="bv-kq-c-nv"><field name="pct_quality" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_quality" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_quality" widget="binary" filename="evidence_quality_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_quality_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">c – % Tiến độ</div>
                                    <div class="bv-kq-c-nv"><field name="pct_progress" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_progress" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_progress" widget="binary" filename="evidence_progress_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_progress_name" invisible="1"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Tiêu chí lãnh đạo — bảng 4 cột -->
                            <div class="bv-kqtnv-section bv-kqtnv-section--mgr" invisible="not is_manager">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Tiêu chí bổ sung (lãnh đạo, quản lý)</div>
                                    <div class="bv-kq-c-nv">NV tự chấm (%)</div>
                                    <div class="bv-kq-c-tp">TK/TP chấm (%)</div>
                                    <div class="bv-kq-c-ev">Minh chứng PDF (NV nộp)</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">d – % Kết quả lĩnh vực</div>
                                    <div class="bv-kq-c-nv"><field name="pct_field_result" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_field_result" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_field_result" widget="binary" filename="evidence_field_result_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_field_result_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">đ – % Tổ chức triển khai</div>
                                    <div class="bv-kq-c-nv"><field name="pct_organization" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_organization" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_organization" widget="binary" filename="evidence_organization_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_organization_name" invisible="1"/>
                                    </div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">e – % Đoàn kết</div>
                                    <div class="bv-kq-c-nv"><field name="pct_team_cohesion" nolabel="1" readonly="1"/></div>
                                    <div class="bv-kq-c-tp"><field name="dept_pct_team_cohesion" nolabel="1" readonly="state != 'submitted'"/></div>
                                    <div class="bv-kq-c-ev">
                                        <field name="evidence_team_cohesion" widget="binary" filename="evidence_team_cohesion_name" nolabel="1" readonly="state != 'submitted'"/>
                                        <field name="evidence_team_cohesion_name" invisible="1"/>
                                    </div>
                                </div>
                            </div>

                            <group>
                                <field name="task_score" readonly="1" decoration-bf="1"/>
                            </group>
                        </page>

                        <page string="III. Nhận xét &amp; Tổng hợp">
                            <div class="bv-kqtnv-section">
                                <div class="bv-kqtnv-head">
                                    <div class="bv-kq-c-label">Khoản mục</div>
                                    <div class="bv-kq-c-nv">NV tự chấm</div>
                                    <div class="bv-kq-c-tp" style="flex:1;">TK/TP chấm (hiện tại)</div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">I. Tiêu chí chung</div>
                                    <div class="bv-kq-c-nv"><field name="general_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="general_score" readonly="1" nolabel="1"/></div>
                                </div>
                                <div class="bv-kqtnv-row">
                                    <div class="bv-kq-c-label">II. Điểm KQTHNV</div>
                                    <div class="bv-kq-c-nv"><field name="task_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="task_score" readonly="1" nolabel="1"/></div>
                                </div>
                                <div class="bv-kqtnv-row" style="font-weight:700;">
                                    <div class="bv-kq-c-label">Tổng điểm</div>
                                    <div class="bv-kq-c-nv"><field name="total_score_nv" readonly="1" nolabel="1"/></div>
                                    <div class="bv-kq-c-tp" style="flex:1;"><field name="total_score" readonly="1" nolabel="1" decoration-bf="1"/></div>
                                </div>
                            </div>
                            <group>
                                <field name="classification" readonly="1" decoration-bf="1"/>
                            </group>
                            <separator string="Nhận xét của trưởng khoa/phòng"/>
                            <group>
                                <field name="strengths" readonly="1" string="NV tự nhận xét ưu điểm"/>
                                <field name="weaknesses" readonly="1" string="NV tự nhận xét hạn chế"/>
                                <field name="authority_comment"
                                       string="Nhận xét của Trưởng khoa/Phòng ✏"
                                       placeholder="Nhận xét, đánh giá của trưởng khoa/phòng..."
                                       groups="bv_danh_gia.group_evaluation_dept_manager"
                                       readonly="state != 'submitted'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ========== LIST VIEW ========== -->
    <record id="view_monthly_evaluation_tree" model="ir.ui.view">
        <field name="name">bv.monthly.evaluation.tree</field>
        <field name="model">bv.monthly.evaluation</field>
        <field name="arch" type="xml">
            <list decoration-success="classification == 'excellent'"
                  decoration-info="classification == 'good'"
                  decoration-warning="classification == 'fair'"
                  decoration-danger="classification == 'poor'">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="general_score"/>
                <field name="task_score"/>
                <field name="total_score" decoration-bf="1"/>
                <field name="classification"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-info="state in ('submitted', 'dept_approved', 'hr_reviewed')"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- ========== SEARCH VIEW ========== -->
    <record id="view_monthly_evaluation_search" model="ir.ui.view">
        <field name="name">bv.monthly.evaluation.search</field>
        <field name="model">bv.monthly.evaluation</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="department_id"/>
            </search>
        </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record id="action_monthly_evaluation" model="ir.actions.act_window">
        <field name="name">Phiếu đánh giá hằng tháng</field>
        <field name="res_model">bv.monthly.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_evaluations': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phiếu tự đánh giá tháng mới
            </p>
            <p>
                Nhân viên tự chấm điểm kết quả thực hiện nhiệm vụ hằng tháng
                theo Mẫu số 01, QĐ 06/2026/QĐ-UBND.
            </p>
        </field>
    </record>

    <!-- Action for department managers — uses dedicated scoring form -->
    <record id="action_monthly_evaluation_dept" model="ir.actions.act_window">
        <field name="name">Duyệt &amp; Chấm điểm (Trưởng Khoa/Phòng)</field>
        <field name="res_model">bv.monthly.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'dept_approved', 'hr_reviewed', 'approved', 'rejected'])]</field>
        <field name="views" eval="[(ref('view_monthly_evaluation_tree'), 'list'), (ref('view_monthly_evaluation_dept_form'), 'form')]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Không có phiếu nào chờ duyệt</p>
            <p>Các phiếu đánh giá của nhân viên trong khoa/phòng đã gửi sẽ xuất hiện ở đây.</p>
        </field>
    </record>

    <!-- Action for HR -->
    <record id="action_monthly_evaluation_hr" model="ir.actions.act_window">
        <field name="name">Xét duyệt phiếu đánh giá (TCCB)</field>
        <field name="res_model">bv.monthly.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['dept_approved', 'hr_reviewed', 'approved', 'rejected'])]</field>
    </record>
</odoo>
