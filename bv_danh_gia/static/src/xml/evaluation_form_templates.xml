<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="bv_danh_gia.EvaluationFormView">
    <div class="bv-eval-form-root">
        <t t-if="state.loading">
            <div style="text-align:center;padding:60px;">
                <i class="fa fa-spinner fa-spin fa-3x" style="color:#c9a84c;"/>
                <p style="margin-top:16px;color:#6b6760;">Đang tải phiếu đánh giá...</p>
            </div>
        </t>
        <t t-elif="!state.record">
            <div style="text-align:center;padding:60px;">
                <p>Không tìm thấy phiếu đánh giá.</p>
                <button class="btn btn-primary" t-on-click="goBack">Quay lại</button>
            </div>
        </t>
        <t t-else="">
            <!-- HEADER -->
            <div class="bv-page-header">
                <div class="bv-header-inner">
                    <div class="bv-header-emblem">&#x1F3E5;</div>
                    <div class="bv-header-text">
                        <div class="bv-header-org">Sở Y tế · Bệnh viện Đa khoa tỉnh</div>
                        <div class="bv-header-title">Phiếu Theo Dõi, Đánh Giá Viên Chức</div>
                        <div class="bv-header-sub">
                            <t t-esc="state.record.is_manager ? 'Mẫu số 02a — Viên chức lãnh đạo, quản lý' : 'Mẫu số 01 — Viên chức không giữ chức vụ'"/>
                        </div>
                    </div>
                    <div class="bv-header-badge">
                        <t t-esc="monthLabel"/> / <t t-esc="state.record.year"/>
                    </div>
                </div>
            </div>

            <div class="bv-eval-layout">
                <!-- ═══ MAIN FORM ═══ -->
                <div class="bv-form-main">

                    <!-- Progress bar -->
                    <div class="bv-form-progress">
                        <div class="bv-form-progress-label">
                            <span>Tiến độ hoàn thành biểu mẫu</span>
                            <span><t t-esc="state.filledCount"/> / <t t-esc="state.totalCriteria"/> tiêu chí</span>
                        </div>
                        <div class="bv-fp-bar">
                            <div class="bv-fp-fill" t-att-style="'width:' + progressPct + '%'"/>
                        </div>
                    </div>

                    <!-- Personal info card -->
                    <div class="bv-card">
                        <div class="bv-section-header">
                            <span class="bv-section-badge">Thông tin</span>
                            <span class="bv-section-title">Thông tin cá nhân</span>
                        </div>
                        <div class="bv-info-grid">
                            <div class="bv-full">
                                <div class="bv-field-label">Họ và tên</div>
                                <div class="bv-field-value"><t t-esc="state.record.employee_id[1]"/></div>
                            </div>
                            <div>
                                <div class="bv-field-label">Đơn vị công tác</div>
                                <div class="bv-field-value"><t t-esc="state.record.department_id ? state.record.department_id[1] : ''"/></div>
                            </div>
                            <div>
                                <div class="bv-field-label">Chức vụ, chức danh</div>
                                <div class="bv-field-value"><t t-esc="state.record.job_id ? state.record.job_id[1] : ''"/></div>
                            </div>
                            <div>
                                <div class="bv-field-label">Kỳ đánh giá</div>
                                <div class="bv-field-value"><t t-esc="monthLabel"/> / <t t-esc="state.record.year"/></div>
                            </div>
                            <div>
                                <div class="bv-field-label">Trạng thái</div>
                                <div class="bv-field-value" style="text-transform:uppercase;font-size:12px;letter-spacing:.06em;">
                                    <t t-esc="state.record.state"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Banner cho trưởng khoa khi chấm lại -->
                    <t t-if="state.canEditDept">
                        <div style="background:#fff8e1;border-left:4px solid #c9a84c;padding:14px 18px;margin-bottom:14px;border-radius:8px;">
                            <strong style="color:#7a5e00;"><i class="fa fa-user-md"/> Bạn đang chấm với tư cách Trưởng khoa/Phòng.</strong>
                            <div style="font-size:13px;color:#5a4500;margin-top:4px;">
                                Cột bên phải mỗi tiêu chí là điểm bạn chấm cho nhân viên. Sau khi xong, bấm <strong>"Duyệt &amp; chuyển lên TCCB"</strong>.
                            </div>
                        </div>
                    </t>

                    <!-- ═══ PHẦN I: TIÊU CHÍ CHUNG ═══ -->
                    <div class="bv-part-divider">
                        <span>PHẦN I — TIÊU CHÍ CHUNG (<t t-esc="state.generalMax"/> điểm)</span>
                    </div>

                    <t t-foreach="state.criteria_groups" t-as="group" t-key="group.id">
                        <div class="bv-card">
                            <div class="bv-section-header">
                                <span class="bv-section-badge">Nhóm <t t-esc="group_index + 1"/></span>
                                <span class="bv-section-title"><t t-esc="group.name"/></span>
                                <span class="bv-section-maxpts">Tối đa: <t t-esc="group.maxScore"/> điểm</span>
                            </div>

                            <t t-foreach="group.criteria" t-as="criterion" t-key="criterion.lineId">
                                <div class="bv-subsection">
                                    <div class="bv-subsection-header">
                                        <div class="bv-subsection-num"><t t-esc="criterion_index + 1"/></div>
                                        <div class="bv-subsection-title"><t t-esc="criterion.name"/></div>
                                        <div class="bv-subsection-pts"><t t-esc="criterion.maxScore"/> điểm</div>
                                        <div class="bv-subsection-score">
                                            <t t-if="criterion.selectedScore > 0"><t t-esc="criterion.selectedScore"/> đ tự chấm</t>
                                            <t t-else="">—</t>
                                        </div>
                                    </div>

                                    <div class="bv-dual-score-row">
                                        <!-- Self-score column -->
                                        <div class="bv-dual-score-col">
                                            <div class="bv-dual-score-label">
                                                <i class="fa fa-user"/> Nhân viên tự chấm
                                            </div>
                                            <div class="bv-dept-input-wrap">
                                                <input type="number" min="0" t-att-max="criterion.maxScore" step="0.5"
                                                       t-att-value="criterion.selectedScore"
                                                       t-att-disabled="state.record.state === 'draft' ? undefined : 'disabled'"
                                                       t-on-input="(ev) => this.updateCriteriaScore(criterion.lineId, ev.target.value, criterion.maxScore)"
                                                       class="bv-dept-input"/>
                                                <span class="bv-dept-input-suffix">/ <t t-esc="criterion.maxScore"/> đ</span>
                                            </div>
                                            <div style="font-size:11px;color:#6b6760;margin-top:4px;">
                                                Nhập điểm trực tiếp cho từng tiêu chí
                                            </div>
                                        </div>

                                        <!-- Dept-score column (visible to dept managers / readonly otherwise) -->
                                        <t t-if="state.canEditDept or (criterion.deptScore and criterion.deptScore > 0)">
                                            <div class="bv-dual-score-col">
                                                <div class="bv-dual-score-label">
                                                    <i class="fa fa-user-md"/> Trưởng khoa/Phòng chấm
                                                </div>
                                                <div class="bv-dept-input-wrap">
                                                    <input type="number" min="0" t-att-max="criterion.maxScore" step="0.5"
                                                           t-att-value="criterion.deptScore"
                                                           t-att-disabled="state.canEditDept ? undefined : 'disabled'"
                                                           t-on-input="(ev) => this.updateDeptScore(criterion.lineId, ev.target.value, criterion.maxScore)"
                                                           class="bv-dept-input"/>
                                                    <span class="bv-dept-input-suffix">/ <t t-esc="criterion.maxScore"/> đ</span>
                                                </div>
                                                <t t-if="!state.canEditDept">
                                                    <div style="font-size:11px;color:#6b6760;margin-top:4px;font-style:italic;">
                                                        Chỉ trưởng khoa được sửa
                                                    </div>
                                                </t>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- ═══ PHẦN II: KẾT QUẢ THỰC HIỆN NHIỆM VỤ ═══ -->
                    <div class="bv-part-divider">
                        <span>PHẦN II — KẾT QUẢ THỰC HIỆN NHIỆM VỤ (<t t-esc="state.taskMax"/> điểm)</span>
                    </div>

                    <!-- Toggle: chế độ lãnh đạo / quản lý -->
                    <div class="bv-manager-toggle-wrap">
                        <button t-on-click="toggleManager"
                                t-att-class="'bv-manager-toggle-btn' + (state.record and state.record.is_manager ? ' active' : '')"
                                t-att-disabled="isReadonly">
                            <i t-att-class="'fa ' + (state.record and state.record.is_manager ? 'fa-check-square-o' : 'fa-square-o')"/>
                            <span style="margin-left:8px;">Đánh giá với tư cách lãnh đạo / Quản lý</span>
                        </button>
                        <span t-if="state.record and state.record.is_manager"
                              class="bv-manager-active-badge">
                            <i class="fa fa-star"/> Đang bật — hiển thị thêm 3 tiêu chí lãnh đạo
                        </span>
                    </div>

                    <div class="bv-card">
                        <div class="bv-section-header">
                            <span class="bv-section-badge">Phần II</span>
                            <span class="bv-section-title">Kết quả thực hiện nhiệm vụ</span>
                            <span class="bv-section-maxpts">Tối đa: 70 điểm · Nhập % hoàn thành</span>
                        </div>

                        <!-- Formula note -->
                        <div style="background:#f5f3ee;padding:10px 24px;border-bottom:1px solid #eceae4;font-size:12px;color:#6b6760;">
                            <i class="fa fa-info-circle"/> Điểm KQTHNV = Trung bình cộng các % nhập vào ÷ 100 × 70.
                            Ví dụ: nhập 80% / 90% / 75% → trung bình 81.67% → điểm = 81.67 ÷ 100 × 70 = <strong>57.2 điểm</strong>.
                        </div>

                        <t t-foreach="state.task_fields" t-as="tf" t-key="tf.key">
                            <t t-if="!tf.managerOnly or (state.record and state.record.is_manager)">
                                <div t-att-style="'border-bottom:1px solid #eceae4;padding:16px 24px;' + (tf.managerOnly ? 'background:#fafaf7;' : '')">
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
                                        <span t-if="tf.managerOnly"
                                              style="font-size:10px;background:#c9a84c;color:#fff;padding:2px 7px;border-radius:10px;font-weight:700;white-space:nowrap;">
                                            Lãnh đạo
                                        </span>
                                        <span style="font-weight:600;font-size:13.5px;flex:1;"><t t-esc="tf.label"/></span>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:12px;">
                                        <input type="number" min="0" max="100" step="0.5"
                                               t-att-value="tf.value"
                                               t-att-disabled="isReadonly ? 'disabled' : undefined"
                                               t-on-input="(ev) => this.updateTaskPct(tf.key, ev.target.value)"
                                               style="width:90px;padding:7px 10px;border:1.5px solid #d8d4cc;border-radius:8px;font-size:15px;text-align:center;outline:none;"/>
                                        <span style="font-size:13px;color:#6b6760;font-weight:600;">%</span>
                                        <div style="flex:1;background:#eceae4;border-radius:6px;height:8px;overflow:hidden;">
                                            <div t-att-style="'background:#0f2044;height:100%;width:' + Math.min(tf.value || 0, 100) + '%;transition:width 0.3s;'"/>
                                        </div>
                                        <span style="font-weight:700;color:#c9a84c;font-size:14px;min-width:48px;text-align:right;">
                                            <t t-if="tf.value"><t t-esc="tf.value"/>%</t>
                                            <t t-else="">—</t>
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </t>

                        <!-- Điểm KQTHNV tổng hợp -->
                        <div style="padding:14px 24px;background:#f5f3ee;display:flex;align-items:center;gap:12px;border-top:2px solid #c9a84c;">
                            <span style="flex:1;font-weight:600;font-size:13px;color:#6b6760;">
                                Điểm KQTHNV (tính theo công thức):
                            </span>
                            <span style="font-size:18px;font-weight:700;color:#0f2044;">
                                <t t-esc="state.totalTask"/> <span style="font-size:13px;color:#6b6760;">/ <t t-esc="state.taskMax"/> điểm</span>
                            </span>
                        </div>
                    </div>

                    <!-- Action bar -->
                    <div class="bv-action-bar">
                        <button class="btn" style="background:transparent;border:1.5px solid #d8d4cc;color:#1e1e1e;padding:11px 24px;border-radius:8px;font-weight:600;cursor:pointer;"
                                t-on-click="openStandardForm">
                            <i class="fa fa-th-list"/> Xem dạng chuẩn
                        </button>
                        <t t-if="state.record and state.record.state === 'draft'">
                            <button class="btn" style="background:transparent;border:1.5px solid #d8d4cc;color:#1e1e1e;padding:11px 24px;border-radius:8px;font-weight:600;cursor:pointer;"
                                    t-on-click="saveDraft" t-att-disabled="state.saving">
                                <i class="fa fa-save"/> Lưu nháp
                            </button>
                            <button class="btn" style="background:#2d7a4f;color:white;padding:11px 24px;border-radius:8px;font-weight:600;border:none;cursor:pointer;"
                                    t-on-click="submitForm" t-att-disabled="state.saving">
                                <i class="fa fa-paper-plane"/> Nộp phiếu đánh giá
                            </button>
                        </t>
                        <t t-elif="state.canEditDept">
                            <button class="btn" style="background:transparent;border:1.5px solid #d8d4cc;color:#1e1e1e;padding:11px 24px;border-radius:8px;font-weight:600;cursor:pointer;"
                                    t-on-click="saveDraft" t-att-disabled="state.saving">
                                <i class="fa fa-save"/> Lưu điểm chấm
                            </button>
                            <button class="btn" style="background:#c9a84c;color:white;padding:11px 24px;border-radius:8px;font-weight:600;border:none;cursor:pointer;"
                                    t-on-click="deptApprove" t-att-disabled="state.saving">
                                <i class="fa fa-check"/> Duyệt &amp; chuyển lên TCCB
                            </button>
                        </t>
                        <t t-else="">
                            <button class="btn" style="background:#0f2044;color:white;padding:11px 24px;border-radius:8px;font-weight:600;border:none;cursor:pointer;"
                                    t-on-click="goBack">
                                <i class="fa fa-arrow-left"/> Quay lại
                            </button>
                        </t>
                    </div>
                </div>

                <!-- ═══ SCORE PANEL ═══ -->
                <div class="bv-score-panel">
                    <div class="bv-score-panel-header">
                        <span style="font-size:18px;">&#x1F3AF;</span>
                        <h3>Bảng điểm thời gian thực</h3>
                    </div>
                    <div class="bv-score-total-display">
                        <div class="bv-score-circle" t-att-style="'background:conic-gradient(#c9a84c ' + scoreDeg + 'deg, #eceae4 0deg);'">
                            <div class="bv-score-number"><t t-esc="state.totalScore"/></div>
                            <div class="bv-score-denom">/ 100</div>
                        </div>
                        <div t-att-class="'bv-score-label ' + classificationDisplay.css">
                            <t t-esc="classificationDisplay.label"/>
                        </div>
                    </div>
                    <div class="bv-score-breakdown">
                        <div class="bv-score-row">
                            <div style="flex:1;">
                                <div style="display:flex;justify-content:space-between;">
                                    <span class="bv-score-row-label">Phần I – Tiêu chí chung</span>
                                    <span class="bv-score-row-val"><t t-esc="state.totalGeneral"/><span class="bv-of"> / <t t-esc="state.generalMax"/></span></span>
                                </div>
                                <div class="bv-progress-bar"><div class="bv-progress-fill" t-att-style="'width:' + generalPct + '%'"/></div>
                            </div>
                        </div>

                        <t t-foreach="state.criteria_groups" t-as="g" t-key="g.id">
                            <div class="bv-score-row" style="padding-left:12px;">
                                <span class="bv-score-row-label" style="font-size:11.5px;">· <t t-esc="g.name.substring(0, 30)"/>...</span>
                                <span class="bv-score-row-val" style="font-size:12px;">
                                    <t t-esc="Math.round(g.currentScore * 10) / 10"/><span class="bv-of"> /<t t-esc="g.maxScore"/></span>
                                </span>
                            </div>
                        </t>

                        <div class="bv-score-row">
                            <div style="flex:1;">
                                <div style="display:flex;justify-content:space-between;">
                                    <span class="bv-score-row-label">Phần II – Kết quả nhiệm vụ</span>
                                    <span class="bv-score-row-val"><t t-esc="state.totalTask"/><span class="bv-of"> / <t t-esc="state.taskMax"/></span></span>
                                </div>
                                <div class="bv-progress-bar"><div class="bv-progress-fill" t-att-style="'width:' + taskPct + '%'"/></div>
                            </div>
                        </div>

                        <div class="bv-score-row" style="border-top:2px solid #c9a84c;margin-top:4px;padding-top:12px;">
                            <span class="bv-score-row-label" style="font-weight:700;">Tổng điểm</span>
                            <span class="bv-score-row-val" style="font-size:16px;color:#c9a84c;">
                                <t t-esc="state.totalScore"/><span class="bv-of"> /100</span>
                            </span>
                        </div>

                        <div style="margin-top:16px;padding:12px;background:#f5f3ee;border-radius:8px;font-size:11.5px;color:#6b6760;line-height:1.8;">
                            <div style="font-weight:700;color:#1e1e1e;margin-bottom:6px;">Thang xếp loại:</div>
                            <div>&#x1F947; <strong>Xuất sắc</strong>: ≥ 90 điểm</div>
                            <div>&#x1F948; <strong>Tốt</strong>: 75 – 89 điểm</div>
                            <div>&#x1F949; <strong>Hoàn thành</strong>: 50 – 74 điểm</div>
                            <div>&#x274C; <strong>Không hoàn thành</strong>: &lt; 50 điểm</div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </div>
</t>

</templates>
