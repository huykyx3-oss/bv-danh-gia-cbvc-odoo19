<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_evaluation" model="ir.module.category">
        <field name="name">Đánh giá xếp loại CBVC</field>
        <field name="sequence">50</field>
    </record>

    <!-- Security Groups -->
    <record id="group_evaluation_user" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="comment">Nhân viên: tự chấm điểm, xem phiếu của mình</field>
    </record>

    <record id="group_evaluation_dept_manager" model="res.groups">
        <field name="name">Trưởng Khoa/Phòng</field>
        <field name="implied_ids" eval="[(4, ref('group_evaluation_user'))]"/>
        <field name="comment">Trưởng khoa/phòng: duyệt phiếu nhân viên trong khoa</field>
    </record>

    <record id="group_evaluation_hr" model="res.groups">
        <field name="name">Phòng TCCB</field>
        <field name="implied_ids" eval="[(4, ref('group_evaluation_dept_manager'))]"/>
        <field name="comment">Phòng Tổ chức cán bộ: tổng hợp, xét duyệt, kiểm tra tỷ lệ</field>
    </record>

    <record id="group_evaluation_director" model="res.groups">
        <field name="name">Ban Giám đốc</field>
        <field name="implied_ids" eval="[(4, ref('group_evaluation_hr'))]"/>
        <field name="comment">Ban Giám đốc: phê duyệt cuối cùng</field>
    </record>

    <!-- Record Rules -->

    <!-- Nhân viên chỉ thấy phiếu của mình -->
    <record id="rule_monthly_eval_user" model="ir.rule">
        <field name="name">Phiếu đánh giá: nhân viên chỉ xem của mình</field>
        <field name="model_id" ref="model_bv_monthly_evaluation"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Trưởng khoa thấy phiếu trong khoa -->
    <record id="rule_monthly_eval_dept_manager" model="ir.rule">
        <field name="name">Phiếu đánh giá: trưởng khoa xem trong khoa</field>
        <field name="model_id" ref="model_bv_monthly_evaluation"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('department_id', 'in', [emp.department_id.id for emp in user.employee_ids])]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_dept_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- TCCB và BGĐ thấy tất cả -->
    <record id="rule_monthly_eval_hr" model="ir.rule">
        <field name="name">Phiếu đánh giá: TCCB xem tất cả</field>
        <field name="model_id" ref="model_bv_monthly_evaluation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_hr'))]"/>
    </record>

    <!-- Quarterly summary rules -->
    <record id="rule_quarterly_user" model="ir.rule">
        <field name="name">Tổng hợp quý: nhân viên chỉ xem của mình</field>
        <field name="model_id" ref="model_bv_quarterly_summary"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_user'))]"/>
    </record>

    <record id="rule_quarterly_hr" model="ir.rule">
        <field name="name">Tổng hợp quý: TCCB xem tất cả</field>
        <field name="model_id" ref="model_bv_quarterly_summary"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_hr'))]"/>
    </record>

    <!-- Yearly classification rules -->
    <record id="rule_yearly_user" model="ir.rule">
        <field name="name">Xếp loại năm: nhân viên chỉ xem của mình</field>
        <field name="model_id" ref="model_bv_yearly_classification"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_user'))]"/>
    </record>

    <record id="rule_yearly_hr" model="ir.rule">
        <field name="name">Xếp loại năm: TCCB xem tất cả</field>
        <field name="model_id" ref="model_bv_yearly_classification"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_evaluation_hr'))]"/>
    </record>
</odoo>
